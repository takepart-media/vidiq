        "issues": "https://github.com/takepart-media/vidiq/issues",
        "source": "https://github.com/takepart-media/vidiq"
    },
    "require": {
        "php": "^8.3",
        "statamic/cms": "^5.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "TakepartMedia\\Vidiq\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TakepartMedia\\Vidiq\\Tests\\": "tests"
        }
    },
    "extra": {
        "statamic": {
            "name": "vidiQ",
            "description": "3q.video hosting platform integration for Statamic"
        },
        "laravel": {
            "providers": [
                "TakepartMedia\\Vidiq\\ServiceProvider"
            ]
        }
